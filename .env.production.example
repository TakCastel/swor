# Production — copier vers .env.production sur le VPS
# cp .env.production.example .env.production

# --- URLs publiques ---
SITE_URL=https://swor.fr
API_URL=https://api.swor.fr

# --- Laravel ---
# Générer avec : cd api && php artisan key:generate --show
APP_KEY=base64:change-me
SANCTUM_STATEFUL_DOMAINS=swor.fr,www.swor.fr
SESSION_DOMAIN=.swor.fr

# --- Postgres ---
POSTGRES_DB=swor
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-password

# --- SMTP (emails transactionnels : vérification, reset password) ---
SMTP_ADMIN_EMAIL=noreply@swor.fr
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
