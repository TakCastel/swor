# Production — copier vers .env.production sur le VPS
# cp .env.production.example .env.production

# --- URLs publiques ---
SITE_URL=https://swor.fr
PUBLIC_SUPABASE_URL=https://api.swor.fr

# --- Supabase (mêmes valeurs que docker/supabase/.env) ---
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_PORT=54322

KONG_PORT=54321
KONG_ADMIN_PORT=54325
STUDIO_PORT=54323

JWT_SECRET=change-me-jwt-secret-at-least-32-characters
JWT_EXPIRY=3600

ANON_KEY=your-anon-key-jwt
SERVICE_ROLE_KEY=your-service-role-key-jwt

# --- Auth / SMTP ---
OPERATOR_TOKEN=change-me-operator-token
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
SMTP_ADMIN_EMAIL=noreply@swor.fr
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Swor
DB_MAX_POOL_SIZE=20
