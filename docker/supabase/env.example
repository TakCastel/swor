# Supabase Self-Hosting Environment Variables
# DONT COMMIT REAL SECRETS TO GIT

POSTGRES_PASSWORD=postgres
POSTGRES_PORT=54322

# Mot de passe du rôle Postgres "authenticator" (utilisé par PostgREST)
AUTHENTICATOR_PASSWORD=postgres

KONG_PORT=54321
KONG_ADMIN_PORT=54325
STUDIO_PORT=54323

# JWT Secret (Must be at least 32 characters)
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# API Keys
# You can generate these or use defaults for local development
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN3b3ItdjIiLCJyb2xlIjoiYW5vbiIsImlhdCI6MTYwMDAwMDAwMCwiZXhwIjoyMDAwMDAwMDAwfQ.placeholder-anon-key
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN3b3ItdjIiLCJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjAwMDAwMDAwMCwiZXhwIjoyMDAwMDAwMDAwfQ.placeholder-service-key

# Auth
SITE_URL=http://localhost:3000
OPERATOR_TOKEN=operator-token
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user
SMTP_PASS=pass
SMTP_SENDER_NAME=Supabase
DB_MAX_POOL_SIZE=20


