{
  "name": "swor",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "front",
    "back"
  ],
  "scripts": {
    "build": "vite build",
    "build:ssr": "vite build && vite build --ssr",
    "dev": "vite",
    "dev:laravel": "composer dev",
    "dev:front": "npm run dev -w front",
    "dev:back": "npm run dev -w back",
    "format": "prettier --write resources/",
    "format:check": "prettier --check resources/",
    "lint": "eslint . --fix",
    "lint:front": "npm run lint -w front",
    "setup": "composer install && npm install && npm run setup:env",
    "setup:env": "test -f .env || cp .env.example .env; test -f docker/supabase/.env || cp docker/supabase/env.example docker/supabase/.env; test -f front/.env.local || cp front/env.local.example front/.env.local; test -f back/.env.local || cp back/env.local.example back/.env.local",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:supabase:up": "docker compose -f docker/supabase/docker-compose.yml --env-file docker/supabase/.env up -d",
    "docker:supabase:down": "docker compose -f docker/supabase/docker-compose.yml --env-file docker/supabase/.env down",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.production down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.production logs -f"
  },
  "devDependencies": {
    "@eslint/js": "^9.19.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react": "^7.37.3",
    "eslint-plugin-react-hooks": "^5.1.0",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "typescript-eslint": "^8.23.0"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.0",
    "@inertiajs/react": "^2.0.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-collapsible": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-toggle": "^1.1.2",
    "@radix-ui/react-toggle-group": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@tailwindcss/vite": "^4.0.6",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.0.1",
    "globals": "^15.14.0",
    "laravel-vite-plugin": "^1.0",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.1",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vite": "^6.0"
  }
}
